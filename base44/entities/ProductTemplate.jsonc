{
  "name": "ProductTemplate",
  "type": "object",
  "description": "Cat\u00e1logo padronizado de tipos de produtos. Cada registro representa uma varia\u00e7\u00e3o \u00fanica de produto. Os fabricantes apenas vinculam seu pre\u00e7o a este template via SupplierProduct.",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome completo padronizado do produto (gerado automaticamente a partir dos atributos)"
    },
    "cod": {
      "type": "string",
      "description": "C\u00f3digo SKU \u00fanico do template (ex: ANI-OLI-EMB-010)"
    },
    "categoria": {
      "type": "string",
      "enum": [
        "Anilhas",
        "Halteres",
        "Dumbells",
        "Tijolinhos",
        "Pisos",
        "Colchonetes",
        "Kettlebells",
        "Kits",
        "Outros"
      ],
      "description": "Categoria principal do produto"
    },
    "subcategoria": {
      "type": "string",
      "description": "Subcategoria espec\u00edfica (ex: Halter Sextavado, Dumbell Sextavado)"
    },
    "tipo_anilha": {
      "type": "string",
      "description": "Tipo construtivo da anilha (ex: Vazada, Injetada, S\u00f3lida, Bumper) - aplic\u00e1vel apenas para Anilhas"
    },
    "tipo_furo": {
      "type": "string",
      "description": "Tipo de furo - aplic\u00e1vel apenas para Anilhas"
    },
    "acabamento": {
      "type": "string",
      "description": "Acabamento/revestimento do produto"
    },
    "pegada": {
      "type": "string",
      "description": "Tipo de pegada - aplic\u00e1vel para Kits (ex: Cromada, Injetada, W Cromada)"
    },
    "peso_faixa": {
      "type": "string",
      "description": "Faixa de peso do kit (ex: 1-10, 12-30, 10-30)"
    },
    "peso_kg": {
      "type": "number",
      "description": "Peso do produto em kg"
    },
    "peso_fracionado": {
      "type": "boolean",
      "default": false,
      "description": "Se \u00e9 peso fracionado (ex: 1.5kg, 2.5kg) - usado em anilhas bumper"
    },
    "barra_acabamento": {
      "type": "string",
      "description": "Acabamento da barra central - aplic\u00e1vel para Halteres"
    },
    "bojo_formato": {
      "type": "string",
      "description": "Formato das extremidades (bojos) - aplic\u00e1vel para Halteres e Dumbells"
    },
    "dumbell_tipo": {
      "type": "string",
      "description": "Tipo construtivo do Dumbell"
    },
    "piso_espessura_mm": {
      "type": "number",
      "description": "Espessura do piso em mm (10 ou 15) - aplic\u00e1vel para Pisos"
    },
    "piso_formato": {
      "type": "string",
      "description": "Formato de montagem do piso"
    },
    "tijolinho_tipo": {
      "type": "string",
      "description": "Tipo de tijolinho - padr\u00e3o ou guia"
    },
    "tijolinho_torre": {
      "type": "string",
      "description": "Torre para a qual o tijolinho \u00e9 compat\u00edvel"
    },
    "und": {
      "type": "string",
      "enum": [
        "pe\u00e7a",
        "par",
        "kg",
        "m\u00b2",
        "kit"
      ],
      "description": "Unidade de venda"
    },
    "foto": {
      "type": "string",
      "description": "URL da foto representativa do tipo de produto (\u00fanica para todos os fabricantes)"
    },
    "google_category": {
      "type": "string",
      "description": "Categoria Google Shopping (ex: Sporting Goods > Exercise & Fitness > Free Weights > Weight Plates)",
      "default": "Sporting Goods > Exercise & Fitness"
    },
    "ncm": {
      "type": "string",
      "description": "C\u00f3digo NCM para fins fiscais",
      "default": "9506.91.00"
    },
    "gtin": {
      "type": "string",
      "description": "C\u00f3digo de barras EAN/GTIN (opcional)"
    },
    "descricao_padrao": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o padronizada do produto para uso no Google Shopping e or\u00e7amentos"
    },
    "ativo": {
      "type": "boolean",
      "default": true,
      "description": "Se este template est\u00e1 ativo no cat\u00e1logo"
    }
  },
  "required": [
    "nome",
    "cod",
    "categoria",
    "und"
  ],
  "x-security": {
    "read": "public",
    "create": "admin",
    "update": "admin",
    "delete": "admin"
  }
}